@article{Duff2002,
    author = {Duff, Iain S. and Heroux, Michael A. and Pozo, Roldan},
    title = {An Overview of the Sparse Basic Linear Algebra Subprograms: The New Standard from the BLAS Technical Forum},
    year = {2002},
