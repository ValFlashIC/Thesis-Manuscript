@Inbook{Baeza-Yates2010_Intersection,
    author="Baeza-Yates, Ricardo
    and Salinger, Alejandro",
    editor="Elomaa, Tapio
    and Mannila, Heikki
    and Orponen, Pekka",
    title="Fast Intersection Algorithms for Sorted Sequences",
    bookTitle="Algorithms and Applications: Essays Dedicated to Esko Ukkonen on the Occasion of His 60th Birthday",
    year="2010",
    publisher="Springer Berlin Heidelberg",
    address="Berlin, Heidelberg",
    pages="45--61",
    abstract="This paper presents and analyzes a simple intersection algorithm for sorted sequences that is fast on average. It is related to the multiple searching problem and to merging. We present the worst and average case analysis, showing that in the former, the complexity nicely adapts to the smallest list size. In the latter case, it performs less comparisons than the total number of elements on both inputs, n and m, when n{\thinspace}={\thinspace}$\alpha$m ($\alpha$>{\thinspace}1), achieving O(m log(n/m)) complexity. The algorithm is motivated by its application to fast query processing in Web search engines, where large intersections, or differences, must be performed fast. In this case we experimentally show that the algorithm is faster than previous solutions.",
    isbn="978-3-642-12476-1",
    doi="10.1007/978-3-642-12476-1_3",
    url="https://doi.org/10.1007/978-3-642-12476-1_3"
